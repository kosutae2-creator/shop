        {{-- Informacije o proizvodu --}}
        <div class="flex flex-col justify-between">
            <div>
                <h1 class="text-3xl md:text-5xl font-black mb-4 italic uppercase tracking-tight">{{ $product->name }}</h1>

                {{-- Cena i popust --}}
                <div class="flex items-center gap-4 mb-6">
                    <p class="text-indigo-600 font-extrabold text-2xl md:text-4xl">
                        {{ number_format($product->price, 0, ',', '.') }} <span class="text-xs md:text-sm">RSD</span>
                    </p>
                    @if($product->hasDiscount())
                        <p class="text-slate-400 line-through text-sm md:text-base font-bold">
                            {{ number_format($product->old_price, 0, ',', '.') }} RSD
                        </p>
                        <span class="bg-rose-500 text-white px-3 py-1 rounded-full text-[10px] md:text-sm font-black uppercase">
                            -{{ $product->discountPercentage() }}%
                        </span>
                    @endif
                </div>

                {{-- Opis proizvoda --}}
                @if($product->description)
                    <p class="text-slate-600 text-sm md:text-base mb-6 leading-relaxed">{{ $product->description }}</p>
                @endif

                {{-- Varijante proizvoda --}}
                <form action="{{ route('cart.store') }}" method="POST" class="space-y-4">
                    @csrf
                    <input type="hidden" name="id" value="{{ $product->id }}">
                    <input type="hidden" name="name" value="{{ $product->name }}">
                    <input type="hidden" name="price" value="{{ $product->price }}">

                    @if($product->variants)
                        @foreach($product->variants as $variant)
                            <div>
                                <label class="block text-slate-500 font-bold text-xs mb-1">{{ $variant['name'] }}</label>
                                <select name="options[{{ $variant['name'] }}]" class="w-full border border-slate-200 rounded-xl px-3 py-2 text-sm outline-none focus:border-indigo-500">
                                    @php $vOptions = explode(',', $variant['options']); @endphp
                                    @foreach($vOptions as $vOpt)
                                        <option value="{{ trim($vOpt) }}">{{ trim($vOpt) }}</option>
                                    @endforeach
                                </select>
                            </div>
                        @endforeach
                    @endif

                    {{-- Količina --}}
                    <div>
                        <label class="block text-slate-500 font-bold text-xs mb-1">Količina</label>
                        <input type="number" name="quantity" value="1" min="1" class="w-24 text-center border border-slate-200 rounded-xl py-2">
                    </div>

                    {{-- Dugme Dodaj u korpu --}}
                    <button type="submit" class="mt-4 w-full md:w-1/2 bg-indigo-600 hover:bg-indigo-500 text-white py-3 rounded-2xl font-black uppercase tracking-widest transition-all shadow-lg active:scale-95">
                        Dodaj u korpu
                    </button>
                </form>
            </div>
        </div>

    </main>

    {{-- Footer --}}
    <footer class="max-w-7xl mx-auto px-4 py-12 text-center text-slate-400 text-[10px] font-black uppercase tracking-widest">
